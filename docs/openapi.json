{"openapi": "3.1.0", "info": {"title": "ollog", "version": "0.1.0"}, "paths": {"/auth/token": {"post": {"tags": ["auth"], "summary": "Login", "description": "OAuth2-compatible login endpoint.\n\nAccepts username + password as form fields.\nReturns a JWT access token on success, 401 on bad credentials.", "operationId": "login_auth_token_post", "requestBody": {"content": {"application/x-www-form-urlencoded": {"schema": {"$ref": "#/components/schemas/Body_login_auth_token_post"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/auth/me": {"get": {"tags": ["auth"], "summary": "Get Me", "description": "Return the authenticated user's profile.", "operationId": "get_me_auth_me_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}, "security": [{"OAuth2PasswordBearer": []}]}}, "/api/qsos/": {"post": {"tags": ["qsos"], "summary": "Create Qso", "description": "Create a new QSO for the authenticated operator.\n\nCallsign is injected from JWT \u2014 not accepted from request body.\nBAND and MODE are uppercased on ingest for compound index consistency.\nExtra ADIF fields beyond the declared set are accepted and stored.\nProfile fields (OPERATOR, STATION_CALLSIGN, etc.) are auto-stamped from the User document.", "operationId": "create_qso_api_qsos__post", "security": [{"OAuth2PasswordBearer": []}, {"APIKeyHeader": []}], "parameters": [{"name": "force", "in": "query", "required": false, "schema": {"type": "boolean", "description": "Override duplicate detection and force insert", "default": false, "title": "Force"}, "description": "Override duplicate detection and force insert"}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/QSOCreateRequest"}}}}, "responses": {"201": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/QSOResponse"}}}}, "409": {"description": "Duplicate QSO detected within +/-2 min window. Use force=true to override.", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DuplicateQSOError"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}, "get": {"tags": ["qsos"], "summary": "List Qsos", "description": "List the authenticated operator's active QSOs with pagination and optional filters.", "operationId": "list_qsos_api_qsos__get", "security": [{"OAuth2PasswordBearer": []}, {"APIKeyHeader": []}], "parameters": [{"name": "page", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 1, "default": 1, "title": "Page"}}, {"name": "page_size", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 500, "minimum": 1, "default": 50, "title": "Page Size"}}, {"name": "call", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Call"}}, {"name": "band", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Band"}}, {"name": "mode", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Mode"}}, {"name": "date_from", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "YYYYMMDD", "title": "Date From"}, "description": "YYYYMMDD"}, {"name": "date_to", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "YYYYMMDD", "title": "Date To"}, "description": "YYYYMMDD"}, {"name": "sort", "in": "query", "required": false, "schema": {"type": "string", "default": "-qso_date_utc", "title": "Sort"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/QSOListResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/qsos/{qso_id}": {"get": {"tags": ["qsos"], "summary": "Get Qso", "description": "Fetch a single QSO by ID. Returns 404 if not found, not owned, or soft-deleted.", "operationId": "get_qso_api_qsos__qso_id__get", "security": [{"OAuth2PasswordBearer": []}, {"APIKeyHeader": []}], "parameters": [{"name": "qso_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Qso Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/QSOResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}, "patch": {"tags": ["qsos"], "summary": "Patch Qso", "description": "Partially update a QSO using raw $set for ADIF field compatibility.\n\nProtected fields (_operator, _deleted, _id) are stripped before update.\nBAND and MODE are uppercased if present. qso_date_utc is recalculated\nif QSO_DATE or TIME_ON changes.", "operationId": "patch_qso_api_qsos__qso_id__patch", "security": [{"OAuth2PasswordBearer": []}, {"APIKeyHeader": []}], "parameters": [{"name": "qso_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Qso Id"}}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "additionalProperties": true, "title": "Body"}}}}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/QSOResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}, "delete": {"tags": ["qsos"], "summary": "Delete Qso", "description": "Soft-delete a QSO by ID.\n\nThe record is marked as deleted in MongoDB \u2014 it is NOT physically removed.\nSoft-deleted QSOs are excluded from all list, get, and export operations.\nTo permanently remove data, direct database access is required.\n\nReturns 204 No Content on success. Returns 404 if not found, not owned,\nor already deleted.", "operationId": "delete_qso_api_qsos__qso_id__delete", "security": [{"OAuth2PasswordBearer": []}, {"APIKeyHeader": []}], "parameters": [{"name": "qso_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Qso Id"}}], "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/adif/import": {"post": {"tags": ["adif"], "summary": "Import Adif", "description": "Import an ADIF file and return a JSON import report.\n\nAccepts .adi or .adif files up to 10 MB.\nReturns a report with accepted, duplicate, and error lists.", "operationId": "import_adif_api_adif_import_post", "requestBody": {"content": {"multipart/form-data": {"schema": {"$ref": "#/components/schemas/Body_import_adif_api_adif_import_post"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ADIFImportReport"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}, "security": [{"OAuth2PasswordBearer": []}]}}, "/api/adif/export": {"get": {"tags": ["adif"], "summary": "Export Adif", "description": "Stream the operator's logbook as a valid .adi file download.\n\nFilters: only the authenticated operator's non-deleted QSOs.\nOutput: ADIF header + one serialized record per QSO.\nMemory: uses StreamingResponse with an async generator.", "operationId": "export_adif_api_adif_export_get", "responses": {"200": {"description": "ADIF (.adi) file download containing the operator's full logbook.", "content": {"text/plain": {}}}}, "security": [{"OAuth2PasswordBearer": []}]}}, "/api/profile/": {"get": {"tags": ["profile"], "summary": "Get Profile", "description": "Return the authenticated operator's profile.\n\nOperator identity is derived exclusively from the JWT \u2014 no callsign\nparameter is accepted. A user with no profile fields set receives\nall-null optional fields (not an error).", "operationId": "get_profile_api_profile__get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProfileResponse"}}}}}, "security": [{"OAuth2PasswordBearer": []}]}, "patch": {"tags": ["profile"], "summary": "Patch Profile", "description": "Update the authenticated operator's profile fields.\n\nOnly fields present in the request body are updated (partial update).\nAbsent fields are left unchanged. If my_gridsquare is updated,\nlatitude and longitude are auto-computed from the grid center.", "operationId": "patch_profile_api_profile__patch", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProfileUpdateRequest"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProfileResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}, "security": [{"OAuth2PasswordBearer": []}]}}, "/api/tokens/": {"get": {"tags": ["tokens"], "summary": "List Tokens", "description": "Return all active (non-revoked) tokens for the authenticated user.", "operationId": "list_tokens_api_tokens__get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"items": {"$ref": "#/components/schemas/TokenResponse"}, "type": "array", "title": "Response List Tokens Api Tokens  Get"}}}}}, "security": [{"OAuth2PasswordBearer": []}]}, "post": {"tags": ["tokens"], "summary": "Create Token", "description": "Create a new API token for the authenticated user.\n\nReturns the full plaintext token exactly once in the response body.\nThe raw token is never stored \u2014 only the HMAC-SHA256 hash is persisted.", "operationId": "create_token_api_tokens__post", "requestBody": {"content": {"application/x-www-form-urlencoded": {"schema": {"$ref": "#/components/schemas/Body_create_token_api_tokens__post"}}}, "required": true}, "responses": {"201": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TokenCreateResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}, "security": [{"OAuth2PasswordBearer": []}]}}, "/api/tokens/{token_id}": {"delete": {"tags": ["tokens"], "summary": "Revoke Token", "description": "Revoke (disable) a token owned by the authenticated user.\n\nSets enabled=False \u2014 the token can no longer be used for authentication.\nReturns 204 No Content on success; 404 if not found or not owned by caller.", "operationId": "revoke_token_api_tokens__token_id__delete", "security": [{"OAuth2PasswordBearer": []}], "parameters": [{"name": "token_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Token Id"}}], "responses": {"204": {"description": "Successful Response"}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/health": {"get": {"summary": "Health", "operationId": "health_health_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/api/whoami": {"get": {"summary": "Whoami", "description": "Protected endpoint that returns the operator callsign from the JWT.\n\nProves the full auth chain works \u2014 callsign comes from JWT, never from request.\nThis endpoint will be replaced by real endpoints in later phases.", "operationId": "whoami_api_whoami_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}, "security": [{"OAuth2PasswordBearer": []}]}}}, "components": {"schemas": {"ADIFImportReport": {"properties": {"total_records": {"type": "integer", "title": "Total Records"}, "accepted": {"items": {"$ref": "#/components/schemas/ADIFRecordAccepted"}, "type": "array", "title": "Accepted"}, "duplicates": {"items": {"$ref": "#/components/schemas/ADIFRecordDuplicate"}, "type": "array", "title": "Duplicates"}, "errors": {"items": {"$ref": "#/components/schemas/ADIFRecordError"}, "type": "array", "title": "Errors"}}, "type": "object", "required": ["total_records", "accepted", "duplicates", "errors"], "title": "ADIFImportReport"}, "ADIFRecordAccepted": {"properties": {"record_index": {"type": "integer", "title": "Record Index"}, "call": {"type": "string", "title": "Call"}, "id": {"type": "string", "title": "Id"}}, "type": "object", "required": ["record_index", "call", "id"], "title": "ADIFRecordAccepted"}, "ADIFRecordDuplicate": {"properties": {"record_index": {"type": "integer", "title": "Record Index"}, "call": {"type": "string", "title": "Call"}, "existing_id": {"type": "string", "title": "Existing Id"}}, "type": "object", "required": ["record_index", "call", "existing_id"], "title": "ADIFRecordDuplicate"}, "ADIFRecordError": {"properties": {"record_index": {"type": "integer", "title": "Record Index"}, "call": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Call"}, "error": {"type": "string", "title": "Error"}}, "type": "object", "required": ["record_index", "error"], "title": "ADIFRecordError"}, "Body_create_token_api_tokens__post": {"properties": {"name": {"type": "string", "title": "Name"}, "expires_at": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Expires At"}}, "type": "object", "required": ["name"], "title": "Body_create_token_api_tokens__post"}, "Body_import_adif_api_adif_import_post": {"properties": {"file": {"type": "string", "contentMediaType": "application/octet-stream", "title": "File"}}, "type": "object", "required": ["file"], "title": "Body_import_adif_api_adif_import_post"}, "Body_login_auth_token_post": {"properties": {"grant_type": {"anyOf": [{"type": "string", "pattern": "^password$"}, {"type": "null"}], "title": "Grant Type"}, "username": {"type": "string", "title": "Username"}, "password": {"type": "string", "format": "password", "title": "Password"}, "scope": {"type": "string", "title": "Scope", "default": ""}, "client_id": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Client Id"}, "client_secret": {"anyOf": [{"type": "string"}, {"type": "null"}], "format": "password", "title": "Client Secret"}}, "type": "object", "required": ["username", "password"], "title": "Body_login_auth_token_post"}, "DuplicateQSOError": {"properties": {"duplicate": {"type": "boolean", "title": "Duplicate"}, "existing_id": {"type": "string", "title": "Existing Id"}, "existing_call": {"type": "string", "title": "Existing Call"}, "existing_band": {"type": "string", "title": "Existing Band"}, "existing_mode": {"type": "string", "title": "Existing Mode"}, "existing_date": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Existing Date"}}, "type": "object", "required": ["duplicate", "existing_id", "existing_call", "existing_band", "existing_mode"], "title": "DuplicateQSOError", "description": "Response schema for 409 Conflict when a duplicate QSO is detected."}, "HTTPValidationError": {"properties": {"detail": {"items": {"$ref": "#/components/schemas/ValidationError"}, "type": "array", "title": "Detail"}}, "type": "object", "title": "HTTPValidationError"}, "ProfileResponse": {"properties": {"callsign": {"type": "string", "title": "Callsign"}, "station_callsign": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Station Callsign"}, "name": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Name"}, "email": {"anyOf": [{"type": "string", "format": "email"}, {"type": "null"}], "title": "Email"}, "qth": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Qth"}, "state": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "State"}, "country": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Country"}, "my_gridsquare": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "My Gridsquare"}, "latitude": {"anyOf": [{"type": "number"}, {"type": "null"}], "title": "Latitude"}, "longitude": {"anyOf": [{"type": "number"}, {"type": "null"}], "title": "Longitude"}, "my_rig": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "My Rig"}, "my_antenna": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "My Antenna"}, "tx_pwr": {"anyOf": [{"type": "number"}, {"type": "null"}], "title": "Tx Pwr"}}, "type": "object", "required": ["callsign"], "title": "ProfileResponse"}, "ProfileUpdateRequest": {"properties": {"station_callsign": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Station Callsign"}, "name": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Name"}, "email": {"anyOf": [{"type": "string", "format": "email"}, {"type": "null"}], "title": "Email"}, "qth": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Qth"}, "state": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "State"}, "country": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Country"}, "my_gridsquare": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "My Gridsquare"}, "my_rig": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "My Rig"}, "my_antenna": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "My Antenna"}, "tx_pwr": {"anyOf": [{"type": "number"}, {"type": "null"}], "title": "Tx Pwr"}}, "type": "object", "title": "ProfileUpdateRequest"}, "QSOCreateRequest": {"properties": {"CALL": {"type": "string", "title": "Call", "description": "Callsign of the contacted station (e.g. W1AW)"}, "QSO_DATE": {"type": "string", "title": "Qso Date", "description": "UTC date of QSO in YYYYMMDD format (e.g. 20240115)"}, "TIME_ON": {"type": "string", "title": "Time On", "description": "UTC start time in HHMM or HHMMSS format (e.g. 1430 or 143045)"}, "BAND": {"type": "string", "title": "Band", "description": "Amateur band designator (e.g. 40m, 20m, 2m)"}, "MODE": {"type": "string", "title": "Mode", "description": "Operating mode per ADIF spec (e.g. SSB, CW, FT8, FM)"}, "FREQ": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Freq", "description": "Frequency in MHz (e.g. 14.225)"}, "RST_SENT": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Rst Sent", "description": "RST signal report sent to contacted station"}, "RST_RCVD": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Rst Rcvd", "description": "RST signal report received from contacted station"}}, "additionalProperties": true, "type": "object", "required": ["CALL", "QSO_DATE", "TIME_ON", "BAND", "MODE"], "title": "QSOCreateRequest", "description": "Request model for QSO creation. extra='allow' captures arbitrary ADIF fields.\n\nOPERATOR and STATION_CALLSIGN are auto-stamped from the authenticated user's\nprofile \u2014 do not include them in the request body. OPERATOR identifies the\nperson at the key; STATION_CALLSIGN identifies the station's licensed callsign."}, "QSOListResponse": {"properties": {"items": {"items": {"$ref": "#/components/schemas/QSOResponse"}, "type": "array", "title": "Items"}, "total": {"type": "integer", "title": "Total"}, "page": {"type": "integer", "title": "Page"}, "page_size": {"type": "integer", "title": "Page Size"}}, "type": "object", "required": ["items", "total", "page", "page_size"], "title": "QSOListResponse", "description": "Paginated list of QSOs."}, "QSOResponse": {"properties": {"id": {"type": "string", "title": "Id"}, "CALL": {"type": "string", "title": "Call"}, "BAND": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Band"}, "MODE": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Mode"}, "qso_date_utc": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Qso Date Utc"}, "_operator": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Operator"}, "_deleted": {"anyOf": [{"type": "boolean"}, {"type": "null"}], "title": "Deleted"}, "FREQ": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Freq"}, "RST_SENT": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Rst Sent"}, "RST_RCVD": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Rst Rcvd"}}, "type": "object", "required": ["id", "CALL"], "title": "QSOResponse", "description": "Response model for a single QSO. Declares stable fields; extra ADIF fields are silently dropped."}, "TokenCreateResponse": {"properties": {"id": {"type": "string", "title": "Id"}, "name": {"type": "string", "title": "Name"}, "token_prefix": {"type": "string", "title": "Token Prefix"}, "created_at": {"type": "string", "format": "date-time", "title": "Created At"}, "expires_at": {"anyOf": [{"type": "string", "format": "date-time"}, {"type": "null"}], "title": "Expires At"}, "enabled": {"type": "boolean", "title": "Enabled"}, "full_token": {"type": "string", "title": "Full Token"}}, "type": "object", "required": ["id", "name", "token_prefix", "created_at", "expires_at", "enabled", "full_token"], "title": "TokenCreateResponse"}, "TokenResponse": {"properties": {"id": {"type": "string", "title": "Id"}, "name": {"type": "string", "title": "Name"}, "token_prefix": {"type": "string", "title": "Token Prefix"}, "created_at": {"type": "string", "format": "date-time", "title": "Created At"}, "expires_at": {"anyOf": [{"type": "string", "format": "date-time"}, {"type": "null"}], "title": "Expires At"}, "enabled": {"type": "boolean", "title": "Enabled"}}, "type": "object", "required": ["id", "name", "token_prefix", "created_at", "expires_at", "enabled"], "title": "TokenResponse"}, "ValidationError": {"properties": {"loc": {"items": {"anyOf": [{"type": "string"}, {"type": "integer"}]}, "type": "array", "title": "Location"}, "msg": {"type": "string", "title": "Message"}, "type": {"type": "string", "title": "Error Type"}, "input": {"title": "Input"}, "ctx": {"type": "object", "title": "Context"}}, "type": "object", "required": ["loc", "msg", "type"], "title": "ValidationError"}}, "securitySchemes": {"OAuth2PasswordBearer": {"type": "oauth2", "flows": {"password": {"scopes": {}, "tokenUrl": "/auth/token"}}}, "APIKeyHeader": {"type": "apiKey", "in": "header", "name": "X-API-Key"}}}}
