# MongoDB connection URI
# Default points to the Docker Compose mongodb service
MONGODB_URI=mongodb://mongodb:27017

# MongoDB database name
MONGODB_DB=ollog

# JWT secret key — MUST be set in production, use a strong random value
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256

# JWT token expiration in minutes (default: 60)
JWT_EXPIRE_MINUTES=60

# Admin bootstrap credentials — set these on first run to create the admin account
# Leave unset after bootstrapping to prevent accidental re-creation
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_CALLSIGN=

# ACLog TCP API bridge manager
# Per-user bridge locations are configured from /log/profile.
ACLOG_ENABLED=true
ACLOG_RECONNECT_SECONDS=5
ACLOG_SCAN_SECONDS=10
